<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="Eva_aplicacionQR.Views.ScannerPage"
             BackgroundColor="#0F172A"
             Title="Escanear QR">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,15,0,10">
            <Label Text="ESCANEAR QR"
                   TextColor="#FFFFFF"
                   FontAttributes="Bold"
                   FontSize="26"
                   HorizontalOptions="Center" />
            <Label Text="Apunta la cámara al código del docente"
                   TextColor="#94A3B8"
                   FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Scanner Area -->
        <Grid Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center">
            <Border Stroke="#6366F1"
                    StrokeThickness="3"
                    StrokeShape="RoundRectangle 20"
                    Background="#1E293B"
                    Padding="4"
                    HeightRequest="290"
                    WidthRequest="290">

                <Grid>
                    <!-- ZXing Camera Reader con tamaño fijo -->
                    <zxing:CameraBarcodeReaderView
                        x:Name="barcodeReader"
                        IsDetecting="False"
                        WidthRequest="280"
                        HeightRequest="280"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        BarcodesDetected="OnBarcodesDetected" />

                    <!-- Línea láser -->
                    <BoxView x:Name="LaserLine"
                             Color="#E11D48"
                             HeightRequest="2"
                             WidthRequest="220"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Opacity="0.8"
                             IsVisible="False"/>

                    <!-- Placeholder -->
                    <VerticalStackLayout x:Name="CameraPlaceholder"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="12"
                                         IsVisible="True">
                        <Label Text="📷" FontSize="52" HorizontalOptions="Center"/>
                        <Label Text="Presiona 'Activar Cámara'"
                               TextColor="#94A3B8" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!-- Panel de Estado y Botones -->
        <VerticalStackLayout Grid.Row="2" Spacing="14" Margin="0,10,0,10">

            <Border Stroke="#334155" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="#1E293B" Padding="15">
                <VerticalStackLayout Spacing="6">
                    <Label x:Name="StatusLabel" Text="🔍 Esperando..." TextColor="#60A5FA" FontAttributes="Bold" FontSize="15" HorizontalOptions="Center" />
                    <Label x:Name="ResultLabel" Text="Código: Ninguno" TextColor="#E2E8F0" FontSize="14" HorizontalOptions="Center" />
                    <Label x:Name="TimestampLabel" Text="Hora: --:--" TextColor="#94A3B8" FontSize="12" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Botones -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                <Button Grid.Column="0" x:Name="ResetBtn" Text="Activar Cámara" Clicked="OnResetClicked" BackgroundColor="#334155" TextColor="#FFFFFF" CornerRadius="8" FontAttributes="Bold" />
                <!-- REGLA ESTRICTA: Botón de Simulación -->
                <Button Grid.Column="1" x:Name="SimulateBtn" Text="Simular Escaneo" Clicked="OnSimulateClicked" BackgroundColor="#F59E0B" TextColor="#0F172A" CornerRadius="8" FontAttributes="Bold" />
            </Grid>
            
            <Button Text="Volver al Menú" Clicked="OnBackClicked" BackgroundColor="Transparent" TextColor="#94A3B8" Margin="0,10,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
