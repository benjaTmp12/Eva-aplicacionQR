<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="Eva_aplicacionQR.MainPage"
             BackgroundColor="#FFFFFF">

    <Grid RowDefinitions="Auto, *, Auto" Padding="30">
        
        <VerticalStackLayout Grid.Row="0" Spacing="8" Margin="0,20,0,20">
            <Label Text="Asistencia"
                   TextColor="#111827"
                   FontAttributes="Bold"
                   FontSize="28"
                   HorizontalOptions="Center" />
            <Label Text="Escanee el código QR"
                   TextColor="#6B7280"
                   FontSize="14"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <Grid Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center">
            <Border Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    HeightRequest="280"
                    WidthRequest="280"
                    BackgroundColor="#F9FAFB">
                <Grid>
                    <zxing:CameraBarcodeReaderView 
                        x:Name="barcodeReader"
                        IsDetecting="False"
                        BarcodesDetected="OnBarcodesDetected" />

                    <VerticalStackLayout x:Name="CameraPlaceholder"
                                         VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="Cámara Inactiva"
                               TextColor="#9CA3AF" FontSize="14"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <VerticalStackLayout Grid.Row="2" Spacing="25" Margin="0,20,0,10">
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label x:Name="StatusLabel"
                       Text="Esperando..."
                       TextColor="#6B7280"
                       FontSize="14"
                       HorizontalOptions="Center" />
                
                <Label x:Name="ResultLabel"
                       Text="--"
                       TextColor="#111827"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />
                
                <Label x:Name="TimestampLabel"
                       Text=""
                       TextColor="#9CA3AF"
                       FontSize="12"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                <Button Grid.Column="0"
                        x:Name="ResetBtn"
                        Text="Activar"
                        Clicked="OnResetClicked"
                        BackgroundColor="#111827"
                        TextColor="#FFFFFF"
                        CornerRadius="6"
                        HeightRequest="48" />
                
                <Button Grid.Column="1"
                        x:Name="SimulateBtn"
                        Text="Simular"
                        Clicked="OnSimulateClicked"
                        BackgroundColor="#F3F4F6"
                        TextColor="#111827"
                        CornerRadius="6"
                        HeightRequest="48" />
            </Grid>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
